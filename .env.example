# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SPRITE_API_TOKEN: Optional shared secret for protecting /api/generate-sprite.
# If set on the server, clients must send this exact value in the `x-sprite-auth` header.
SPRITE_API_TOKEN="MY_SPRITE_SHARED_TOKEN"

# VITE_SPRITE_API_TOKEN: Client-side value used by the browser to send x-sprite-auth.
# For local dev, set this to the same value as SPRITE_API_TOKEN.
VITE_SPRITE_API_TOKEN="MY_SPRITE_SHARED_TOKEN"

# SPRITE_AUTH_MODE: one of auto | firebase | token | none
# auto: prefer firebase if Firebase admin creds are available, else token if SPRITE_API_TOKEN is set.
SPRITE_AUTH_MODE="auto"

# FIREBASE_SERVICE_ACCOUNT_JSON: either full JSON content or a file path to service account JSON.
# Required for SPRITE_AUTH_MODE=firebase unless GOOGLE_APPLICATION_CREDENTIALS is configured.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# SPRITE_ALLOW_ANONYMOUS_AUTH: allow anonymous Firebase users to generate sprites.
# Defaults to false; keeping it false better protects paid AI usage.
SPRITE_ALLOW_ANONYMOUS_AUTH="false"

# SPRITE_AUTH_ALLOWED_EMAILS: optional comma-separated allowlist for sprite generation.
SPRITE_AUTH_ALLOWED_EMAILS="you@example.com,teammate@example.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
